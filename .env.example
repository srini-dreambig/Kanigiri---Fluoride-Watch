# Neon PostgreSQL (required for API / gallery / mandal storage)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# API server port (default 3001)
PORT=3001

# Optional: Gemini API
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Frontend URL (optional)
APP_URL="http://localhost:3069"

# Vite proxy uses relative /api in dev. On Vercel, leave unset (same-origin /api).
# Set only if the API is hosted on a different domain:
# VITE_API_URL="https://your-api.example.com"

# --- Vercel (Project → Settings → Environment Variables) ---
# DATABASE_URL   required for /api gallery & mandals
# GEMINI_API_KEY optional
